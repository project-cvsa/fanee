{
	"name": "fanee",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"test": "bunx --bun turbo run test",
		"test:coverage": "bunx --bun turbo run test:coverage",
		"dev": "bunx --bun turbo run dev",
		"build": "bunx --bun turbo run build",
		"lint": "bunx --bun turbo run lint",
		"typecheck": "bunx --bun turbo run typecheck",
		"format": "biome format --write .",
		"ci": "bunx --bun turbo run ci"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.10",
		"@typescript/native-preview": "^7.0.0-dev.20260618.1",
		"turbo": "^2.8.18"
	},
	"packageManager": "bun@1.3.11"
