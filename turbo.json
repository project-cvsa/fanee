{
	"remoteCache": {
		"enabled": true
	},
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["build"]
		},
		"test": {
			"dependsOn": ["build"]
		},
		"test:coverage": {
			"dependsOn": ["build"]
		},
		"typecheck": {
			"dependsOn": ["build"]
		},
		"ci": {
			"dependsOn": ["typecheck", "test", "lint"]
		}
	}
}
