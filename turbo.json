{
	"remoteCache": {
		"enabled": true
	},
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".output/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"test": {},
		"test:coverage": {},
		"typecheck": {}
	}
}
